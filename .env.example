# ---------- ANTHROPIC (IA) ----------
# Acesse: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# ---------- SUPABASE (Banco de dados) ----------
# Acesse: https://supabase.com → Seu projeto → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXX
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXX

# ---------- STRIPE (Pagamentos) ----------
# Acesse: https://dashboard.stripe.com → Developers → API Keys
STRIPE_KEY=sua_chave_do_stripe_aqui.
# Acesse: https://dashboard.stripe.com → Products → Seu produto → Price ID
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX
# Acesse: https://dashboard.stripe.com → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---------- URL DO SEU SITE ----------
# Coloque a URL do seu site no Vercel depois de fazer deploy
NEXT_PUBLIC_URL=https://radar-invisivel.vercel.app
