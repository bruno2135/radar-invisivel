{
  "version": 2,
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/checkout.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/ai.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
